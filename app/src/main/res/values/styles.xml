<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tambahkan ini sebagai base/parent -->
    <style name="Text">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="Text.Title">
        <item name="android:textSize">@dimen/text_hl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="Text.BodyMuted">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">#757575</item>
    </style>

    <style name="SurnoteCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_marginBottom">@dimen/space_md</item>
    </style>

</resources>